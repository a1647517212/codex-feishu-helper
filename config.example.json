{
  "machine": {
    "id": "desktop-windows",
    "name": "Windows Codex Desktop"
  },
  "server": {
    "host": "127.0.0.1",
    "port": 8787,
    "adminToken": "${FEISHU_CODEX_ADMIN_TOKEN}"
  },
  "codex": {
    "command": "${CODEX_COMMAND:-codex}",
    "args": ["app-server"],
    "connectionMode": "auto",
    "proxyArgs": ["app-server", "proxy"],
    "experimentalApi": true,
    "defaultModel": "gpt-5.4",
    "defaultReasoningEffort": "xhigh",
    "defaultSandboxMode": "danger-full-access",
    "defaultApprovalPolicy": "never",
    "autoArchiveOnCompletion": true,
    "serviceName": "feishu_codex_bridge"
  },
  "feishu": {
    "appId": "${FEISHU_APP_ID}",
    "appSecret": "${FEISHU_APP_SECRET}",
    "defaultChatId": "${FEISHU_DEFAULT_CHAT_ID}",
    "verificationToken": "${FEISHU_VERIFICATION_TOKEN}",
    "encryptKey": "${FEISHU_ENCRYPT_KEY}",
    "transport": "long_connection",
    "messageTransport": "long_connection",
    "cardActionTransport": "long_connection",
    "interactionMode": "hybrid",
    "taskContainerMode": "dedicated_chat",
    "taskChatNamePrefix": "C",
    "taskChatType": "private",
    "taskChatFallbackToTopic": true,
    "taskChatSetBotManager": true,
    "allowedUserIds": ["${FEISHU_ALLOWED_USER_IDS}"],
    "allowedChatIds": ["${FEISHU_ALLOWED_CHAT_IDS}"]
  },
  "storage": {
    "homeDir": "~/.feishu-codex",
    "databasePath": "~/.feishu-codex/bridge.db",
    "logPath": "~/.feishu-codex/bridge.log"
  },
  "bridge": {
    "maxFeishuTextLength": 3500,
    "queueMergeWindowMs": 300000,
    "outboxRetryBaseMs": 15000,
    "outboxMaxAttempts": 8,
    "threadListLimit": 20
  },
  "projects": []
}
