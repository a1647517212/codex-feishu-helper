{
  "name": "codex-feishu-helper",
  "version": "0.1.0",
  "description": "Local Feishu control bridge for ordinary Codex Desktop task chats.",
  "type": "module",
  "bin": {
    "feishu-codex": "./dist/src/main.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/main.ts serve",
    "start": "node dist/src/main.js serve",
    "doctor": "tsx src/main.ts doctor",
    "panel": "powershell -ExecutionPolicy Bypass -File scripts/open-control-panel.ps1",
    "shortcuts": "powershell -ExecutionPolicy Bypass -File scripts/install-user-shortcuts.ps1",
    "watchdog": "powershell -ExecutionPolicy Bypass -File scripts/install-watchdog.ps1",
    "generate:codex-schema": "node scripts/generate-codex-schema.mjs",
    "test": "node --no-warnings=ExperimentalWarning --test --import tsx \"tests/**/*.test.ts\"",
    "check": "npm run build && npm test"
  },
  "keywords": [
    "codex",
    "feishu",
    "lark",
    "bridge",
    "desktop-ipc"
  ],
  "author": "",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@larksuiteoapi/node-sdk": "^1.63.1",
    "zod": "^4.3.6"
  },
  "overrides": {
    "axios": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
